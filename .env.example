# =============================================================================
# FinSight — Environment Template
# =============================================================================
#
# This file is a TEMPLATE. To run the app, copy it to a file called
# .env.local in the same directory, then fill in the value for OPENAI_API_KEY.
#
#     cp .env.example .env.local
#
# .env.local is automatically ignored by git (see .gitignore), so your secret
# key won't be accidentally committed or pushed to GitHub.
#
# NEVER commit any file containing a real API key.
# -----------------------------------------------------------------------------


# -- LLM Provider -------------------------------------------------------------
#
# This app talks to a Large Language Model over an OpenAI-compatible REST API.
# The defaults below are configured for Groq (the provider used in the NYU
# class demo) because it is free, has no credit-card requirement, and the
# inference is fast enough to feel instant during a live demo.
#
# How to get a Groq API key (takes about 2 minutes):
#   1. Go to https://console.groq.com
#   2. Sign up with email or Google SSO. No credit card needed.
#   3. Click "API Keys" in the left sidebar, then "Create API Key".
#   4. Copy the key (it starts with "gsk_").
#   5. Paste it as the value for OPENAI_API_KEY below.
#
# If you would rather use a different provider, see the alternatives at the
# bottom of this file.

DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=                                   # <-- paste your gsk_... key here
OPENAI_API_URL=https://api.groq.com/openai
OPENAI_API_TYPE=openai
DEFAULT_LLM_MODEL=llama-3.3-70b-versatile


# -- Database ------------------------------------------------------------------
# These are set automatically when you run `docker compose up` and point at the
# Postgres container. You generally do not need to change them.

DATABASE_URL=postgresql+asyncpg://finsight:finsight@db:5432/finsight
SYNC_DATABASE_URL=postgresql://finsight:finsight@db:5432/finsight


# -- SEC / Financial Data ------------------------------------------------------
# The SEC requires a user-agent string identifying who is calling the API.
# Replace this with your own school email if you'd like.

SEC_USER_AGENT=student.demo@example.com


# -- App -----------------------------------------------------------------------

LOG_LEVEL=info


# =============================================================================
# OPTIONAL: Alternative providers
# =============================================================================
# If you have a key for OpenAI, OpenRouter, or Google Gemini, comment out the
# Groq config above and uncomment ONE of the blocks below.

# # -- OpenAI (https://platform.openai.com) -----------------------------------
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_API_URL=https://api.openai.com
# OPENAI_API_TYPE=openai
# DEFAULT_LLM_MODEL=gpt-4o-mini

# # -- OpenRouter (https://openrouter.ai) -------------------------------------
# DEFAULT_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_API_URL=https://openrouter.ai/api
# OPENAI_API_TYPE=openai
# DEFAULT_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# # -- Google Gemini (https://aistudio.google.com) ----------------------------
# DEFAULT_LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash


# =============================================================================
# OPTIONAL: SSL escape hatch for corporate networks
# =============================================================================
# Some corporate networks (Big-4 firms, banks, etc.) perform "SSL inspection"
# on outgoing HTTPS traffic. Python may reject those connections with a
# CERTIFICATE_VERIFY_FAILED error. If you can't use a non-corporate network,
# uncomment the line below to disable certificate verification.
#
# This is unsafe in any real environment. Only use it for this class demo.
#
# INSECURE_SSL_VERIFY=true
